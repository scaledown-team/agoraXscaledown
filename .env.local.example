# ===========================================
# Agora x ScaleDown — Environment Variables
# ===========================================
# Copy this file to .env.local and fill in your keys
# cp .env.local.example .env.local

# --- Agora (voice infrastructure) ---
NEXT_PUBLIC_AGORA_APP_ID=your_agora_app_id
AGORA_APP_CERTIFICATE=your_agora_app_certificate
AGORA_CUSTOMER_ID=your_agora_customer_id
AGORA_CUSTOMER_SECRET=your_agora_customer_secret
NEXT_PUBLIC_AGORA_BOT_UID=1001

# --- Deepgram (speech-to-text / ASR) ---
DEEPGRAM_API_KEY=your_deepgram_api_key

# --- ElevenLabs (text-to-speech / TTS — optional, requires paid plan for API) ---
ELEVENLABS_API_KEY=your_elevenlabs_api_key

# --- Cartesia (text-to-speech / TTS — recommended, free tier works) ---
CARTESIA_API_KEY=your_cartesia_api_key
CARTESIA_VOICE_ID=your_cartesia_voice_id

# --- Groq (LLM — free, OpenAI-compatible) ---
LLM_BASE_URL=https://api.groq.com/openai/v1
LLM_API_KEY=your_groq_api_key
LLM_MODEL=llama-3.3-70b-versatile

# --- ScaleDown (context compression) ---
SCALEDOWN_API_KEY=your_scaledown_api_key
SCALEDOWN_API_URL=https://api.scaledown.xyz

# --- LangSmith (tracing & benchmarks — optional) ---
LANGCHAIN_TRACING_V2=true
LANGCHAIN_API_KEY=your_langsmith_api_key
LANGCHAIN_PROJECT=agora-x-scaledown

# --- Proxy (REQUIRED for ScaleDown mode in local dev) ---
# Agora's cloud agent needs to reach your /api/llm-proxy endpoint.
# Use ngrok: ngrok http 3000, then paste the URL here.
# Example: PROXY_BASE_URL=https://abc123.ngrok-free.app
PROXY_BASE_URL=https://your-ngrok-url.ngrok-free.app

# --- Benchmarking mode ---
# Set to "true" to run without ScaleDown (baseline), "false" to enable compression
BASELINE_MODE=true
